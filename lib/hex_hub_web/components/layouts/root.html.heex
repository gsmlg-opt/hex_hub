<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]" data-theme="sunshine">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <script>
      (function() {
        var t = localStorage.getItem("theme");
        if (t && t !== "default") document.documentElement.setAttribute("data-theme", t);
        else if (t === "default") document.documentElement.removeAttribute("data-theme");
      })();
    </script>
    <.live_title default="HexHub" suffix=" · HexHub">
      {assigns[:page_title]}
    </.live_title>
    <link
      phx-track-static
      rel="stylesheet"
      href={
        DuskmoonBundler.static_path(HexHubWeb.Endpoint, "/assets/public/css/app.css",
          profile: :hex_hub
        )
      }
    />
    <script
      defer
      phx-track-static
      type="module"
      src={
        DuskmoonBundler.static_path(HexHubWeb.Endpoint, "/assets/public/js/app.js",
          profile: :hex_hub
        )
      }
    >
    </script>
  </head>
  <body class="bg-surface antialiased">
    {@inner_content}
  </body>
</html>
