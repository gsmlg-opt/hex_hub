<Layouts.app flash={@flash}>
  <.docs_layout current_page={@current_page} page_title={@page_title}>
    <div class="max-w-none">
      <!-- Page header -->
      <div class="mb-10">
        <div class="flex items-center gap-2 text-sm text-on-surface-variant mb-3">
          <a href="/docs" class="hover:text-primary transition-colors">Documentation</a>
          <.dm_mdi name="chevron-right" class="w-4 h-4 opacity-40" />
          <span class="text-on-surface font-medium">MCP Integration</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight text-on-surface mb-4">
          MCP Integration
        </h1>
        <p class="text-lg text-on-surface-variant leading-relaxed max-w-2xl">
          HexHub exposes a <strong>Model Context Protocol (MCP)</strong> server that allows AI clients
          to query packages, resolve dependencies, and access documentation programmatically via JSON-RPC 2.0.
        </p>
      </div>

      <!-- Overview -->
      <.section_heading id="overview" level={2}>Overview</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        The MCP server is an optional component that can be enabled at runtime. It provides a standard
        JSON-RPC 2.0 interface over HTTP, allowing AI assistants and tools to interact with your
        private Hex registry.
      </p>

      <.callout type="info" title="MCP Protocol Version">
        HexHub implements MCP protocol version <code class="font-mono text-xs">2024-11-05</code>.
        Compatible with Claude, Cursor, and other MCP-enabled clients.
      </.callout>

      <!-- Capabilities -->
      <.section_heading id="capabilities" level={2}>Capabilities</.section_heading>

      <div class="grid sm:grid-cols-2 gap-3 mb-6">
        <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/40 bg-surface">
          <div class="w-9 h-9 rounded-lg bg-primary/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="package-variant" class="w-5 h-5" color="var(--color-primary)" />
          </div>
          <div>
            <p class="font-semibold text-sm text-on-surface">Package Management</p>
            <p class="text-xs text-on-surface-variant mt-0.5">Search, retrieve, and list Hex packages</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/40 bg-surface">
          <div class="w-9 h-9 rounded-lg bg-secondary/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="source-branch" class="w-5 h-5" color="var(--color-secondary)" />
          </div>
          <div>
            <p class="font-semibold text-sm text-on-surface">Release Management</p>
            <p class="text-xs text-on-surface-variant mt-0.5">List, compare, and download releases</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/40 bg-surface">
          <div class="w-9 h-9 rounded-lg bg-tertiary/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="file-document-outline" class="w-5 h-5" color="var(--color-tertiary)" />
          </div>
          <div>
            <p class="font-semibold text-sm text-on-surface">Documentation Access</p>
            <p class="text-xs text-on-surface-variant mt-0.5">Fetch and search package documentation</p>
          </div>
        </div>
        <div class="flex items-start gap-3 p-4 rounded-xl border border-outline-variant/40 bg-surface">
          <div class="w-9 h-9 rounded-lg bg-info/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="graph-outline" class="w-5 h-5" color="var(--color-info)" />
          </div>
          <div>
            <p class="font-semibold text-sm text-on-surface">Dependency Resolution</p>
            <p class="text-xs text-on-surface-variant mt-0.5">Resolve dependencies and check compatibility</p>
          </div>
        </div>
      </div>

      <!-- Enabling the MCP Server -->
      <.section_heading id="enabling" level={2}>Enabling the MCP Server</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        The MCP server is disabled by default. Enable it using environment variables:
      </p>

      <.code_block label="Environment Variables">
        <pre class="text-on-surface"><code><span class="text-on-surface-variant"># Enable the MCP server</span>
<span class="text-success font-semibold">export</span> <span class="text-info">MCP_ENABLED</span>=true

<span class="text-on-surface-variant"># Optional: disable authentication for public access</span>
<span class="text-success font-semibold">export</span> <span class="text-info">MCP_REQUIRE_AUTH</span>=false

<span class="text-on-surface-variant"># Optional: set rate limit (requests per hour per IP, default: 1000)</span>
<span class="text-success font-semibold">export</span> <span class="text-info">MCP_RATE_LIMIT</span>=1000</code></pre>
      </.code_block>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        Or start HexHub with MCP enabled inline:
      </p>

      <.code_block label="Terminal">
        <pre class="text-on-surface"><code>MCP_ENABLED=true MCP_REQUIRE_AUTH=false ./bin/hex_hub start</code></pre>
      </.code_block>

      <!-- Endpoints -->
      <.section_heading id="endpoints" level={2}>Endpoints</.section_heading>

      <div class="rounded-xl border border-outline-variant/40 overflow-hidden mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-container-high/50">
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Method</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Path</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/20">
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><span class={method_badge_class("post")}>POST</span></td>
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded">/mcp</code></td>
              <td class="px-4 py-3 text-on-surface-variant">JSON-RPC 2.0 request handler</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><span class={method_badge_class("get")}>GET</span></td>
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded">/mcp/tools</code></td>
              <td class="px-4 py-3 text-on-surface-variant">List available MCP tools</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><span class={method_badge_class("get")}>GET</span></td>
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded">/mcp/server-info</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Server information and capabilities</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><span class={method_badge_class("get")}>GET</span></td>
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded">/mcp/health</code></td>
              <td class="px-4 py-3 text-on-surface-variant">MCP service health check</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Available Tools -->
      <.section_heading id="available-tools" level={2}>Available Tools ({@tool_count})</.section_heading>

      <p class="text-on-surface-variant mb-6 leading-relaxed">
        The MCP server exposes {@tool_count} tools organized into functional groups.
        Each tool can be called via the <code class="text-sm bg-surface-container-high px-1.5 py-0.5 rounded font-mono">tools/call/&lt;tool_name&gt;</code> JSON-RPC method.
      </p>

      <%= for group <- @tool_groups do %>
        <div class="mb-8" id={"tools-#{String.downcase(String.replace(group.name, " ", "-"))}"}>
          <div class="flex items-center gap-2 mb-4">
            <div class={"w-7 h-7 rounded-lg bg-#{group.color}/12 flex items-center justify-center shrink-0"}>
              <.dm_mdi name={group.icon} class="w-4 h-4" color={"var(--color-#{group.color})"} />
            </div>
            <h3 class="text-lg font-bold text-on-surface">{group.name}</h3>
            <span class="text-xs text-on-surface-variant bg-surface-container-high px-2 py-0.5 rounded-full">
              {length(group.tools)} tools
            </span>
          </div>

          <div class="space-y-3">
            <%= for tool <- group.tools do %>
              <div
                class="rounded-xl border border-outline-variant/40 overflow-hidden"
                id={"tool-#{tool.name}"}
              >
                <!-- Tool Header -->
                <div class="px-4 py-3 bg-surface-container-low/50 border-b border-outline-variant/30">
                  <div class="flex items-center gap-2 flex-wrap">
                    <code class={"font-mono text-sm font-bold text-#{group.color}"}>{tool.name}</code>
                    <span class="text-on-surface-variant text-sm">&mdash;</span>
                    <span class="text-sm text-on-surface-variant">{tool.description}</span>
                  </div>
                </div>

                <div class="p-4 space-y-4">
                  <!-- Input Parameters -->
                  <div>
                    <h4 class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">
                      Input Parameters
                    </h4>
                    <%= if tool.input_schema && tool.input_schema["properties"] && map_size(tool.input_schema["properties"]) > 0 do %>
                      <div class="rounded-lg border border-outline-variant/30 overflow-hidden">
                        <table class="w-full text-sm">
                          <thead>
                            <tr class="bg-surface-container-high/30">
                              <th class="text-left px-3 py-2 text-xs font-semibold text-on-surface-variant border-b border-outline-variant/20">Name</th>
                              <th class="text-left px-3 py-2 text-xs font-semibold text-on-surface-variant border-b border-outline-variant/20">Type</th>
                              <th class="text-left px-3 py-2 text-xs font-semibold text-on-surface-variant border-b border-outline-variant/20">Required</th>
                              <th class="text-left px-3 py-2 text-xs font-semibold text-on-surface-variant border-b border-outline-variant/20">Description</th>
                            </tr>
                          </thead>
                          <tbody class="divide-y divide-outline-variant/15">
                            <%= for {param_name, param_spec} <- Enum.sort_by(tool.input_schema["properties"], fn {name, _} ->
                              if name in (tool.input_schema["required"] || []), do: "0_#{name}", else: "1_#{name}"
                            end) do %>
                              <tr>
                                <td class="px-3 py-2">
                                  <code class="font-mono text-xs font-semibold text-on-surface">{param_name}</code>
                                </td>
                                <td class="px-3 py-2">
                                  <code class="font-mono text-xs px-1.5 py-0.5 rounded bg-surface-container-high text-on-surface-variant">{param_spec["type"]}</code>
                                </td>
                                <td class="px-3 py-2">
                                  <%= if param_name in (tool.input_schema["required"] || []) do %>
                                    <span class="inline-flex items-center text-xs font-medium text-warning">
                                      <.dm_mdi name="check-circle" class="w-3.5 h-3.5 mr-0.5" color="var(--color-warning)" />
                                      yes
                                    </span>
                                  <% else %>
                                    <span class="text-xs text-on-surface-variant">no</span>
                                  <% end %>
                                </td>
                                <td class="px-3 py-2 text-xs text-on-surface-variant">{param_spec["description"]}</td>
                              </tr>
                            <% end %>
                          </tbody>
                        </table>
                      </div>
                    <% else %>
                      <p class="text-sm text-on-surface-variant italic">No parameters required</p>
                    <% end %>
                  </div>

                  <!-- JSON-RPC Example -->
                  <div>
                    <h4 class="text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2">
                      Example Request
                    </h4>
                    <div class="rounded-lg border border-outline-variant/30 overflow-hidden">
                      <div class="flex items-center gap-2 px-3 py-1.5 bg-surface-container-high/60 border-b border-outline-variant/20">
                        <.dm_mdi name="file-code-outline" class="w-3.5 h-3.5 text-on-surface-variant/60" />
                        <span class="text-xs font-mono text-on-surface-variant/70">JSON-RPC</span>
                      </div>
                      <div class="p-3 bg-surface-container-high/20 overflow-x-auto">
                        <pre class="text-xs font-mono text-on-surface whitespace-pre"><code>{build_tool_example(tool)}</code></pre>
                      </div>
                    </div>
                  </div>

                  <!-- Input Schema -->
                  <details class="group">
                    <summary class="cursor-pointer text-xs font-bold text-on-surface-variant uppercase tracking-wider mb-2 flex items-center gap-1 select-none">
                      <.dm_mdi name="chevron-right" class="w-4 h-4 group-open:rotate-90 transition-transform" />
                      Full JSON Schema
                    </summary>
                    <div class="rounded-lg border border-outline-variant/30 overflow-hidden mt-2">
                      <div class="p-3 bg-surface-container-high/20 overflow-x-auto">
                        <pre class="text-xs font-mono text-on-surface whitespace-pre"><code>{Jason.encode!(tool.input_schema, pretty: true)}</code></pre>
                      </div>
                    </div>
                  </details>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Authentication -->
      <.section_heading id="authentication" level={2}>Authentication</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        When <code class="text-sm bg-surface-container-high px-1.5 py-0.5 rounded font-mono">MCP_REQUIRE_AUTH=true</code> (the default),
        clients must authenticate using one of the following methods:
      </p>

      <.section_heading id="bearer-token" level={3}>Bearer Token</.section_heading>

      <.code_block label="HTTP Header">
        <pre class="text-on-surface"><code>Authorization: Bearer your_api_key</code></pre>
      </.code_block>

      <.section_heading id="basic-auth" level={3}>Basic Authentication</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        Use <code class="text-sm bg-surface-container-high px-1.5 py-0.5 rounded font-mono">mcp</code> as the username and your API key as the password:
      </p>

      <.code_block label="HTTP Header">
        <pre class="text-on-surface"><code>Authorization: Basic base64("mcp:your_api_key")</code></pre>
      </.code_block>

      <.section_heading id="query-param" level={3}>Query Parameter</.section_heading>

      <.code_block label="URL">
        <pre class="text-on-surface"><code><%= @mcp_url %>?api_key=your_api_key</code></pre>
      </.code_block>

      <.callout type="warning" title="Security">
        When authentication is disabled (<code class="font-mono text-xs">MCP_REQUIRE_AUTH=false</code>),
        all MCP endpoints are publicly accessible. Only disable authentication in trusted network environments.
      </.callout>

      <!-- JSON-RPC Usage -->
      <.section_heading id="json-rpc" level={2}>JSON-RPC Usage</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        The MCP server accepts JSON-RPC 2.0 requests at the <code class="text-sm bg-surface-container-high px-1.5 py-0.5 rounded font-mono">POST /mcp</code> endpoint.
      </p>

      <.section_heading id="initialize" level={3}>Initialize Connection</.section_heading>

      <.code_block label="Request">
        <pre class="text-on-surface"><code>curl -X POST <%= @mcp_url %> \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer your_api_key" \
  -d '&#123;
    "jsonrpc": "2.0",
    "id": 1,
    "method": "initialize",
    "params": &#123;&#125;
  &#125;'</code></pre>
      </.code_block>

      <.code_block label="Response">
        <pre class="text-on-surface"><code>&#123;
  "jsonrpc": "2.0",
  "id": 1,
  "result": &#123;
    "protocolVersion": "2024-11-05",
    "capabilities": &#123;
      "tools": &#123; "listChanged": true &#125;,
      "logging": &#123;&#125;
    &#125;,
    "serverInfo": &#123;
      "name": "HexHub MCP Server",
      "version": "1.0.0"
    &#125;
  &#125;
&#125;</code></pre>
      </.code_block>

      <.section_heading id="list-tools" level={3}>List Available Tools</.section_heading>

      <.code_block label="Request">
        <pre class="text-on-surface"><code>curl -X POST <%= @mcp_url %> \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer your_api_key" \
  -d '&#123;
    "jsonrpc": "2.0",
    "id": 2,
    "method": "tools/list",
    "params": &#123;&#125;
  &#125;'</code></pre>
      </.code_block>

      <.section_heading id="call-tool" level={3}>Call a Tool</.section_heading>

      <.code_block label="Request">
        <pre class="text-on-surface"><code>curl -X POST <%= @mcp_url %> \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer your_api_key" \
  -d '&#123;
    "jsonrpc": "2.0",
    "id": 3,
    "method": "tools/call/search_packages",
    "params": &#123;
      "arguments": &#123;
        "query": "phoenix"
      &#125;
    &#125;
  &#125;'</code></pre>
      </.code_block>

      <!-- Client Configuration -->
      <.section_heading id="client-config" level={2}>Client Configuration</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        Configure your AI client to connect to HexHub's MCP server.
      </p>

      <.section_heading id="claude-desktop" level={3}>Claude Desktop</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        Add HexHub to your Claude Desktop MCP configuration:
      </p>

      <.code_block label="claude_desktop_config.json">
        <pre class="text-on-surface"><code>&#123;
  "mcpServers": &#123;
    "hexhub": &#123;
      "url": "<%= @mcp_url %>",
      "headers": &#123;
        "Authorization": "Bearer your_api_key"
      &#125;
    &#125;
  &#125;
&#125;</code></pre>
      </.code_block>

      <.section_heading id="claude-code" level={3}>Claude Code</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        Add HexHub to your Claude Code MCP settings:
      </p>

      <.code_block label=".mcp.json">
        <pre class="text-on-surface"><code>&#123;
  "mcpServers": &#123;
    "hexhub": &#123;
      "type": "url",
      "url": "<%= @mcp_url %>",
      "headers": &#123;
        "Authorization": "Bearer your_api_key"
      &#125;
    &#125;
  &#125;
&#125;</code></pre>
      </.code_block>

      <!-- Environment Variables -->
      <.section_heading id="environment-variables" level={2}>Environment Variables</.section_heading>

      <div class="rounded-xl border border-outline-variant/40 overflow-hidden mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-container-high/50">
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Variable</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Default</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/20">
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded text-info">MCP_ENABLED</code></td>
              <td class="px-4 py-3 text-on-surface-variant"><code class="text-xs font-mono">false</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Enable or disable the MCP server</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded text-info">MCP_REQUIRE_AUTH</code></td>
              <td class="px-4 py-3 text-on-surface-variant"><code class="text-xs font-mono">true</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Require API key authentication</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono bg-surface-container-high px-1.5 py-0.5 rounded text-info">MCP_RATE_LIMIT</code></td>
              <td class="px-4 py-3 text-on-surface-variant"><code class="text-xs font-mono">1000</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Requests per hour per IP address</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Error Handling -->
      <.section_heading id="error-handling" level={2}>Error Handling</.section_heading>

      <p class="text-on-surface-variant mb-4 leading-relaxed">
        The MCP server returns standard JSON-RPC 2.0 error codes:
      </p>

      <div class="rounded-xl border border-outline-variant/40 overflow-hidden mb-6">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-container-high/50">
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Code</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Message</th>
              <th class="text-left px-4 py-3 font-semibold text-on-surface border-b border-outline-variant/30">Description</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant/20">
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32700</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Parse error</td>
              <td class="px-4 py-3 text-on-surface-variant">Invalid JSON in request body</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32600</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Invalid Request</td>
              <td class="px-4 py-3 text-on-surface-variant">Request does not conform to JSON-RPC 2.0</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32601</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Method not found</td>
              <td class="px-4 py-3 text-on-surface-variant">Requested method or tool does not exist</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32602</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Invalid params</td>
              <td class="px-4 py-3 text-on-surface-variant">Tool arguments failed validation</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32001</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Unauthorized</td>
              <td class="px-4 py-3 text-on-surface-variant">Missing or invalid API key</td>
            </tr>
            <tr class="hover:bg-surface-container-low/50 transition-colors">
              <td class="px-4 py-3"><code class="text-xs font-mono">-32002</code></td>
              <td class="px-4 py-3 text-on-surface-variant">Rate limited</td>
              <td class="px-4 py-3 text-on-surface-variant">Too many requests, retry after cooldown</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Next Steps -->
      <.section_heading id="next-steps" level={2}>Next Steps</.section_heading>

      <div class="space-y-3">
        <a
          href="/docs/api-reference"
          class="group flex items-center gap-3 p-3 rounded-xl border border-outline-variant/40 hover:border-primary/30 hover:bg-primary/3 transition-all"
        >
          <div class="w-9 h-9 rounded-lg bg-tertiary/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="code-braces" class="w-5 h-5" color="var(--color-tertiary)" />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-sm text-on-surface">API Reference</span>
            <p class="text-xs text-on-surface-variant">Explore the complete HexHub REST API documentation</p>
          </div>
          <.dm_mdi name="chevron-right" class="w-5 h-5 text-on-surface-variant/40 group-hover:text-primary transition-colors" />
        </a>
        <a
          href="/docs/publishing"
          class="group flex items-center gap-3 p-3 rounded-xl border border-outline-variant/40 hover:border-primary/30 hover:bg-primary/3 transition-all"
        >
          <div class="w-9 h-9 rounded-lg bg-secondary/12 flex items-center justify-center shrink-0">
            <.dm_mdi name="package-variant-closed-plus" class="w-5 h-5" color="var(--color-secondary)" />
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-sm text-on-surface">Publishing Packages</span>
            <p class="text-xs text-on-surface-variant">Publish packages that MCP clients can discover</p>
          </div>
          <.dm_mdi name="chevron-right" class="w-5 h-5 text-on-surface-variant/40 group-hover:text-primary transition-colors" />
        </a>
      </div>
    </div>
  </.docs_layout>
</Layouts.app>
